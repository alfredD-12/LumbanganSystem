{
    "require": {
        "dompdf/dompdf": "^3.1"
    },
    "require-dev": {
        "pestphp/pest": "^3.8"
    },
    "scripts": {
        "test": "vendor/bin/pest --testsuite=Unit,Feature,Integration",
        "test:unit": "vendor/bin/pest --testsuite=Unit",
        "test:feature": "vendor/bin/pest --testsuite=Feature",
        "test:integration": "vendor/bin/pest --testsuite=Integration",
        "test:all": "vendor/bin/pest --testsuite=Unit,Feature,Integration"
    },
    "autoload-dev": {
        "classmap": [
            "tests/Support/"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
