APP_ENV=production
BMIS_BASE_FOLDER=/bmis-lumbangan-system/

BMIS_DB_HOST=localhost
BMIS_DB_PORT=3306
BMIS_DB_NAME=lumbangansystem
BMIS_DB_USERNAME=root
BMIS_DB_PASSWORD=

BMIS_TEST_DB_HOST=localhost
BMIS_TEST_DB_PORT=3306
BMIS_TEST_DB_NAME=lumbangansystem_test
BMIS_TEST_DB_USERNAME=root
BMIS_TEST_DB_PASSWORD=

BRUTE_FORCE_PROTECTION_ENABLED=true
RATE_LIMIT_IP_MAX_ATTEMPTS=5
RATE_LIMIT_IP_WINDOW_MINUTES=1
ACCOUNT_RATE_LIMIT_MAX_FAILURES=8
ACCOUNT_RATE_LIMIT_WINDOW_MINUTES=15
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_BASE_MINUTES=15
ACCOUNT_LOCKOUT_MAX_MINUTES=120
ACCOUNT_LOCKOUT_BACKOFF_MULTIPLIER=2
CAPTCHA_TRIGGER_THRESHOLD=4
PASSWORD_RESET_REQUEST_MAX_ATTEMPTS=3
PASSWORD_RESET_REQUEST_WINDOW_MINUTES=15
PASSWORD_RESET_REQUEST_CAPTCHA_TRIGGER_THRESHOLD=2
PASSWORD_RESET_VERIFY_MAX_FAILURES=5
PASSWORD_RESET_VERIFY_WINDOW_MINUTES=15
PASSWORD_RESET_VERIFY_CAPTCHA_TRIGGER_THRESHOLD=3
PASSWORD_RESET_SUBMIT_MAX_FAILURES=5
PASSWORD_RESET_SUBMIT_WINDOW_MINUTES=15
PASSWORD_RESET_SUBMIT_CAPTCHA_TRIGGER_THRESHOLD=3
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60

CSRF_FIELD_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-TOKEN

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.5

EMAIL_METHOD=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=
SMTP_PASSWORD=
SENDER_EMAIL=noreply@barangaylumbangan.gov.ph
SENDER_NAME=Barangay Lumbangan
SECURITY_ALERT_EMAIL=
