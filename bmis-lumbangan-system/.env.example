REGISTRATION_REQUEST_MAX_ATTEMPTS=3
REGISTRATION_REQUEST_WINDOW_MINUTES=15
REGISTRATION_REQUEST_CAPTCHA_ALWAYS=true
REGISTRATION_VERIFY_MAX_FAILURES=5
REGISTRATION_VERIFY_WINDOW_MINUTES=15
REGISTRATION_VERIFY_CAPTCHA_TRIGGER_THRESHOLD=3

CSRF_FIELD_NAME=csrf_token
